# ─── DATABASE ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string — use SSL in production
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/payment_control?schema=public&sslmode=require"

# ─── NEXTAUTH ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="REPLACE_WITH_STRONG_RANDOM_SECRET_MIN_32_CHARS"
NEXTAUTH_URL="https://your-domain.com"

# ─── ENCRYPTION ───────────────────────────────────────────────────────────────
# AES-256 key — must be exactly 64 hex chars (32 bytes)
# Generate: openssl rand -hex 32
APP_ENCRYPTION_KEY="REPLACE_WITH_64_HEX_CHARS"

# HMAC key for audit log integrity
# Generate: openssl rand -hex 32
AUDIT_HMAC_KEY="REPLACE_WITH_64_HEX_CHARS"

# ─── REDIS (BullMQ) ──────────────────────────────────────────────────────────
# Redis with TLS and authentication
REDIS_URL="rediss://:PASSWORD@localhost:6380"

# ─── EMAIL SENDING (SMTP) ─────────────────────────────────────────────────────
SMTP_HOST="smtp.your-provider.com"
SMTP_PORT="587"
SMTP_SECURE="true"
SMTP_USER="noreply@your-domain.com"
SMTP_PASSWORD="REPLACE_WITH_SMTP_PASSWORD"
SMTP_FROM_NAME="Controle Financeiro"
SMTP_FROM_EMAIL="noreply@your-domain.com"

# ─── EMAIL RECEIVING (IMAP) ──────────────────────────────────────────────────
IMAP_HOST="imap.your-provider.com"
IMAP_PORT="993"
IMAP_SECURE="true"
IMAP_USER="pagamentos@your-domain.com"
IMAP_PASSWORD="REPLACE_WITH_IMAP_PASSWORD"

# Email webhook HMAC secret (for POST /api/email/ingest)
EMAIL_WEBHOOK_SECRET="REPLACE_WITH_STRONG_SECRET"

# Comma-separated list of allowed sender domains
EMAIL_ALLOWED_DOMAINS="@trusted-supplier.com,@bank.com"

# ─── FILE STORAGE ─────────────────────────────────────────────────────────────
# S3-compatible (AWS S3 or MinIO)
STORAGE_ENDPOINT="https://s3.amazonaws.com"
STORAGE_BUCKET="payment-attachments-prod"
STORAGE_ACCESS_KEY="REPLACE"
STORAGE_SECRET_KEY="REPLACE"
STORAGE_REGION="us-east-1"

# Max attachment size in bytes (default 5MB)
MAX_ATTACHMENT_SIZE="5242880"

# ─── ANTIMALWARE ──────────────────────────────────────────────────────────────
# ClamAV daemon socket or REST API
CLAMAV_HOST="localhost"
CLAMAV_PORT="3310"

# ─── RATE LIMITING ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS="60000"
RATE_LIMIT_MAX_REQUESTS="100"
AUTH_RATE_LIMIT_MAX="5"

# ─── APPLICATION ──────────────────────────────────────────────────────────────
NODE_ENV="production"
APP_URL="https://your-domain.com"

# Session timeout in seconds (default 30 min)
SESSION_MAX_AGE="1800"

# Email extraction confidence threshold (0.0 - 1.0)
EMAIL_EXTRACTION_THRESHOLD="0.75"

# ─── NEVER COMMIT THIS FILE WITH REAL VALUES ──────────────────────────────────
# Use a secrets manager (AWS Secrets Manager, HashiCorp Vault, etc.) in production
